  "opportunity_filter": {
    "_comment": "Pre-AI filter. Items must match at least one REQUIRE keyword and zero BLOCK keywords. Case-insensitive word boundaries.",

    "require_one_of": [
      "architect", "architecture", "architectural",
      "urban design", "urban planning", "landscape architect",
      "interior design", "spatial design",
      "built environment", "civic design",
      "design competition", "open call", "call for entries",
      "call for submissions", "call for papers", "call for proposals",
      "call for abstracts", "call for projects",
      "design grant", "architecture grant",
      "design fellowship", "architecture fellowship",
      "design residency", "architecture residency",
      "architecture award", "design award", "architecture prize",
      "architecture exhibition", "design exhibition",
      "public art", "art commission",
      "biennale", "pavilion",
      "design challenge", "architecture challenge",
      "housing design", "sustainable design",
      "heritage architecture", "adaptive reuse"
    ],

    "block_if_found": [
      "archery", "bow and arrow",
      "sports competition", "football competition", "soccer competition",
      "basketball", "baseball", "cricket", "golf tournament",
      "swimming competition", "tennis tournament",
      "esports", "gaming competition",
      "cooking competition", "baking competition",
      "beauty competition", "fashion competition",
      "car competition", "automobile",
      "job listing", "we are hiring", "now hiring",
      "real estate listing", "for sale", "for rent"
    ],

    "must_be_opportunity_not_news": {
      "_comment": "These patterns indicate a news article about a project, NOT an opportunity to enter. Gemini AI does the main filtering; this is a regex hint.",
      "news_indicators": [
        "wins competition", "winner of", "awarded to",
        "completed project", "project complete",
        "opens to the public", "recently opened",
        "unveils", "reveals design",
        "breaks ground", "under construction"
      ]
    }
  },

  "categories": {
    "Competition":        { "color": "#166534", "bg": "#dcfce7", "description": "Architecture, urban, landscape, or design competitions requiring a submission. Must be open to enter." },
    "Grant":              { "color": "#6b21a8", "bg": "#f3e8ff", "description": "Funding grants for design research, projects, or practice development." },
    "Fellowship":         { "color": "#1e40af", "bg": "#dbeafe", "description": "Fellowship programs offering stipends, mentorship, or funded research periods." },
    "Residency":          { "color": "#0f766e", "bg": "#ccfbf1", "description": "Design or architecture residency programs, typically offering space, time, and/or funding." },
    "Journal/CFP":        { "color": "#9d174d", "bg": "#fce7f3", "description": "Call for papers, abstracts, or project submissions to peer-reviewed journals or publications." },
    "Award":              { "color": "#92400e", "bg": "#fef3c7", "description": "Awards or prizes for completed work, submitted for recognition. Not requiring new design work." },
    "Exhibition/Biennale":{ "color": "#9f1239", "bg": "#ffe4e6", "description": "Open calls for works to be exhibited, or applications to participate in biennales or curated shows." },
    "Public Art/RFQ":     { "color": "#075985", "bg": "#e0f2fe", "description": "Public art commissions, requests for qualifications, or requests for proposals for built works." },
    "Conference":         { "color": "#334155", "bg": "#f1f5f9", "description": "Conference or symposium calls for papers, presentations, or participation." },
    "Other":              { "color": "#64748b", "bg": "#f8fafc", "description": "Opportunities that don't fit neatly into the above categories." }
  },

  "opportunity_schema": {
    "_comment": "This is the shape of each item in data/opportunities.json",
    "fields": {
      "id":           { "type": "string",  "description": "Hash of URL+title, used for deduplication" },
      "title":        { "type": "string",  "description": "Title of the opportunity" },
      "url":          { "type": "string",  "description": "Direct URL to the opportunity" },
      "source":       { "type": "string",  "description": "Feed name or 'Web Search' or 'Site Scrape'" },
      "source_type":  { "type": "string",  "enum": ["rss", "google_alert", "web_search", "site_scrape"] },
      "found_date":   { "type": "string",  "description": "ISO date when first discovered (YYYY-MM-DD)" },
      "pub_date":     { "type": "string",  "description": "Original publication date from feed, if available" },
      "description":  { "type": "string",  "description": "One-sentence summary produced by Gemini" },
      "category":     { "type": "string",  "enum_ref": "categories" },
      "deadline":     { "type": "string",  "description": "Extracted deadline string (e.g. '30 Jun 2026') or '' if unknown" },
      "fee":          { "type": "string",  "description": "'Free', fee amount (e.g. '€60'), or 'Unknown'" },
      "prize":        { "type": "string",  "description": "Prize or value if applicable (e.g. '€10,000')" },
      "is_new":       { "type": "boolean", "description": "True if added in the most recent collection run" },
      "ai_verified":  { "type": "boolean", "description": "True if Gemini has analyzed this item" }
    }
  }
}
